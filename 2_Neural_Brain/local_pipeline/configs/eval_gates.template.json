{
  "version": 1,
  "description": "Promotion gates for local neural shadow evaluation before prefer-mode (contract v1).",
  "require_freeze_ready": true,
  "require_manifest_sync": true,
  "max_integrity_failures": 0,
  "minimum_holdout_rows": 1000,
  "holdout_no_rowid_overlap": true,
  "holdout_no_feature_hash_overlap": true,
  "max_decision_latency_p50_sec": 1.5,
  "max_decision_latency_p95_sec": 5.0,
  "max_decision_latency_p99_sec": 10.0,
  "max_feature_extract_p99_ms": 1.0,
  "min_bb100_delta_vs_fast_live": 5.0,
  "minimum_rows": 100,
  "max_neural_elapsed_p95_sec": 2.0,
  "min_agree_rate_overall": 0.7,
  "min_agree_rate_by_street": {
    "flop": 0.65,
    "turn": 0.7,
    "river": 0.72
  },
  "min_agree_rate_by_runtime_profile": {
    "fast_live": 0.7,
    "normal": 0.75
  },
  "max_disagreement_rows_for_review": 500,
  "max_surrogate_rate": 0.5
}
